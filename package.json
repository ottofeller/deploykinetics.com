{
  "name": "microfeller",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "svelte:check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "svelte:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "eslint:check": "eslint .",
    "eslint:fix": "eslint . --fix",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "check:all": "npm run eslint:check && npm run prettier:check && npm run svelte:check",
    "fix:all": "npm run prettier:fix && npm run eslint:fix"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@floating-ui/dom": "1.7.5",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.51.0",
    "@sveltejs/vite-plugin-svelte": "6.2.4",
    "@tailwindcss/vite": "4.1.18",
    "@types/eslint": "9.6.1",
    "@types/eslint-config-prettier": "6.11.3",
    "@types/fontkit": "2.0.8",
    "@types/subset-font": "2.3.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-svelte": "3.15.0",
    "espree": "10.4.0",
    "fontkit": "2.0.4",
    "globals": "17.3.0",
    "htmlnano": "3.1.0",
    "prettier": "3.8.1",
    "prettier-plugin-svelte": "3.4.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "sharp": "0.34.5",
    "shiki": "3.22.0",
    "subset-font": "2.4.0",
    "svelte": "5.51.1",
    "svelte-check": "4.4.0",
    "tailwindcss": "4.1.18",
    "terser": "5.46.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.55.0",
    "vite": "7.3.1"
  },
  "type": "module"
}
